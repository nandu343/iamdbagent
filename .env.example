# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Connection to your Neo4j instance (default matches docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=secret

# ── LLM Backend (choose one) ──────────────────────────────────────────────────
# Option A: Anthropic (recommended — best risk scoring quality)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI
# OPENAI_API_KEY=sk-...

# Option C: Ollama (local, no key needed)
# Start Ollama: docker compose --profile ollama up -d
# Then pull a model: docker exec -it <ollama_container_id> ollama pull llama2

# ── SailPoint IdentityNow (required for fetch-sailpoint) ──────────────────────
# Create a dedicated API client in SailPoint Admin → API Management → OAuth Clients
# SAILPOINT_TENANT_URL=https://your-org.api.identitynow.com
# SAILPOINT_CLIENT_ID=your-client-id
# SAILPOINT_CLIENT_SECRET=your-client-secret

# ── AWS (required for fetch-aws) ──────────────────────────────────────────────
# Uses your default AWS credentials if not set.
# AWS_PROFILE=default
